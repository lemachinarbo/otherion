{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "otherion",
  "outputfilename": "otherion",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "info": {
    "companyName": "Otherion",
    "productName": "Otherion",
    "productVersion": "0.2.0",
    "comments": "A modern email client customized for Omarchy Linux",
    "protocols": [
      {
        "scheme": "mailto",
        "description": "Email"
      }
    ]
  },
  "author": {
    "name": "Otherion",
    "email": "dev@otherion.org"
  }
}
